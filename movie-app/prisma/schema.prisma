// Prisma schema — models the app's data layer for Supabase/PostgreSQL.
// Run `npx prisma migrate dev` once DATABASE_URL is set in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  watchlist     WatchlistItem[]
  history       HistoryEntry[]
  reviews       Review[]
}

enum Plan {
  FREE
  STANDARD
  PREMIUM
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Title {
  id          Int      @id // TMDB id
  mediaType   String // movie | tv | anime
  title       String
  overview    String   @db.Text
  posterPath  String
  backdropPath String
  releaseYear Int
  rating      Float
  genres      Json
  createdAt   DateTime @default(now())

  favorites   Favorite[]
  watchlist   WatchlistItem[]
  history     HistoryEntry[]
  reviews     Review[]
}

model Favorite {
  id      String @id @default(cuid())
  userId  String
  titleId Int
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  titleId Int
  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model HistoryEntry {
  id         String   @id @default(cuid())
  userId     String
  titleId    Int
  progress   Float    @default(0) // 0-1
  watchedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  titleId   Int
  rating    Int
  content   String   @db.Text
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)
}
